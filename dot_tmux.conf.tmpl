# ============================================================
# tmux Configuration
# ============================================================
# Managed by shellkit (chezmoi)
# Local overrides: ~/.tmux.conf.local

# --- General ------------------------------------------------
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:Tc"
set -g mouse on
set -g history-limit 200000
set -g focus-events on
set -g allow-passthrough on
set -g renumber-windows on
set -g automatic-rename on
set -g base-index 1
setw -g pane-base-index 1
set -sg escape-time 10
setw -g mode-keys vi

# --- Splits (| and - are more intuitive) --------------------
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# --- Pane navigation (vim-style) ----------------------------
bind -r h select-pane -L
bind -r j select-pane -D
bind -r k select-pane -U
bind -r l select-pane -R

# --- Resize panes (Alt + vim keys) --------------------------
bind -n M-h resize-pane -L 5
bind -n M-j resize-pane -D 5
bind -n M-k resize-pane -U 5
bind -n M-l resize-pane -R 5

# --- Clipboard ----------------------------------------------
{{- if eq .os_type "macos" }}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "pbcopy"
{{- else }}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
bind-key -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"
{{- end }}

# --- Nested tmux (press prefix twice to send to inner) ------
bind C-b send-prefix

# --- Snippets (Ctrl-b S: fzf pick → paste into pane) ---------
bind S display-popup -E -w 80% -h 60% "file=$(ls -1 ~/.tmux/snippets 2>/dev/null | fzf --preview 'cat ~/.tmux/snippets/{}' --preview-window=right:60%:wrap --prompt='snippet> ') && tmux load-buffer ~/.tmux/snippets/$file && tmux paste-buffer"

# --- Help (Ctrl-b ?: quick reference in popup) ---------------
bind ? display-popup -E -w 80% -h 80% "echo '\
 SESSIONS                         WINDOWS (TABS)              \n\
 ta        attach recent          Ctrl-b c    new window      \n\
 tns NAME  new session            Ctrl-b n/p  next/prev       \n\
 tls       list sessions          Ctrl-b 1-9  jump to window  \n\
 tks NAME  kill session           Ctrl-b ,    rename window   \n\
 Ctrl-b d  detach                 Ctrl-b w    picker          \n\
 tw PATH   repo workspace         Ctrl-b &    close window    \n\
                                                              \n\
 PANES (SPLITS)                   SNIPPETS                    \n\
 Ctrl-b |  split horizontal       Ctrl-b S    paste snippet   \n\
 Ctrl-b -  split vertical         snip new    create snippet  \n\
 Ctrl-b hjkl  navigate            snip edit   edit snippet    \n\
 Alt-hjkl  resize                 snip rm     delete snippet  \n\
 Ctrl-b z  zoom/fullscreen                                    \n\
 Ctrl-b x  close pane             COPY MODE                   \n\
 Ctrl-b {  swap up                Ctrl-b [    enter copy mode \n\
 Ctrl-b }  swap down              v           start selection \n\
 Ctrl-b Space cycle layouts       y           yank to clipboard\n\
                                  q           exit copy mode  \n\
 PERSISTENCE                                                  \n\
 Ctrl-b Ctrl-s  save session      OTHER                       \n\
 Ctrl-b Ctrl-r  restore session   Ctrl-b Ctrl-b  nested tmux  \n\
 auto-save every 5 min            Ctrl-b r       reload config\n\
' | less -R"

# --- Reload config ------------------------------------------
bind r source-file ~/.tmux.conf \; display-message "tmux.conf reloaded"

# --- Pane borders (visible borders make drag-resize easier) --
set -g pane-border-style "fg=colour240"
set -g pane-active-border-style "fg=green,bold"
set -g pane-border-lines heavy

# --- Status line --------------------------------------------
set -g status on
set -g status-interval 2
set -g status-left-length 50
set -g status-right-length 100
set -g status-left "#[fg=green]#S #[fg=white]| #[fg=cyan]#W "
set -g status-right "#[fg=yellow]%Y-%m-%d #[fg=magenta]%H:%M"

# --- TPM + Persistence Plugins -----------------------------
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'

set -g @continuum-restore 'on'
set -g @continuum-save-interval '5'
set -g @resurrect-capture-pane-contents 'on'
set -g @resurrect-strategy-nvim 'session'

# --- Local overrides ----------------------------------------
if-shell "[ -f ~/.tmux.conf.local ]" "source-file ~/.tmux.conf.local"

# --- TPM init (must be at very bottom) ----------------------
run '~/.tmux/plugins/tpm/tpm'
