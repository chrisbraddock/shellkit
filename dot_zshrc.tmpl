# ============================================================
# Zsh Configuration
# ============================================================
# Managed by chezmoi - shellkit
# ============================================================

# Terminfo fallback (e.g. xterm-ghostty without installed terminfo)
if ! infocmp "$TERM" &>/dev/null 2>&1; then
    export TERM=xterm-256color
fi

# Startup timing (for shellkit metrics)
typeset -gF SHELLKIT_ZSH_START=$EPOCHREALTIME

# ------------------------------------------------------------
# Auto-start tmux (full profile only)
# ------------------------------------------------------------
{{ if eq .profile "full" -}}
if [[ -z "$TMUX" ]] && [[ -z "$_SHELLKIT_RC_SOURCED" ]] \
   && command -v tmux &>/dev/null \
   && [[ "$TERM_PROGRAM" != "vscode" ]] \
   && [[ -z "$INSIDE_EMACS" ]] \
   && [[ -z "$ZELLIJ" ]]; then
    if [[ -n "$CMUX_WORKSPACE_ID" || -n "$CMUX_BUNDLE_ID" ]]; then
        # cmux: isolated tmux socket per workspace (prevents session collisions)
        local _repo_name="${PWD:t}"
        _repo_name="${_repo_name//[^[:alnum:]]/_}"
        exec tmux -L "ws_${_repo_name}" new-session -A -s main
    else
        exec tmux new-session -A -s main
    fi
fi
{{- end }}
typeset -g _SHELLKIT_RC_SOURCED=1

# ------------------------------------------------------------
# Powerlevel10k Instant Prompt (must be at top)
# ------------------------------------------------------------
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ------------------------------------------------------------
# Zsh Options
# ------------------------------------------------------------

# History — fully isolated per shell session
HISTFILE="$HOME/.zsh_history.$$"
HISTSIZE=50000
SAVEHIST=50000

setopt EXTENDED_HISTORY          # Write timestamps to history
setopt HIST_EXPIRE_DUPS_FIRST    # Expire duplicates first when trimming
setopt HIST_IGNORE_DUPS          # Don't record immediate duplicates
setopt HIST_IGNORE_ALL_DUPS      # Delete old recorded entry if new is duplicate
setopt HIST_IGNORE_SPACE         # Don't record lines starting with space
setopt HIST_FIND_NO_DUPS         # Don't display duplicates in search
setopt HIST_REDUCE_BLANKS        # Remove superfluous blanks
setopt HIST_VERIFY               # Don't execute immediately on history expansion
setopt APPEND_HISTORY            # Append to history file (don't overwrite)
setopt INC_APPEND_HISTORY        # Add commands immediately (for crash protection)

# Merge session history into main file on exit, then clean up
autoload -Uz add-zsh-hook
_shellkit_merge_history() {
    local main="$HOME/.zsh_history"
    [[ -f "$HISTFILE" ]] || return 0
    # Append session history to main file
    fc -W "$HISTFILE"
    cat "$HISTFILE" >> "$main" 2>/dev/null
    rm -f "$HISTFILE"
}
add-zsh-hook zshexit _shellkit_merge_history

# Directory navigation
setopt AUTO_CD                   # cd by typing directory name
setopt AUTO_PUSHD                # Push old directory onto stack
setopt PUSHD_IGNORE_DUPS         # Don't push duplicates
setopt PUSHD_SILENT              # Don't print stack after pushd/popd

# Completion
setopt COMPLETE_IN_WORD          # Complete from both ends of word
setopt ALWAYS_TO_END             # Move cursor to end after completion
setopt NO_LIST_BEEP              # Don't beep on ambiguous completion

# Misc
setopt CORRECT                   # Command spell correction
setopt NO_BG_NICE                # Don't nice background jobs
setopt NO_HUP                    # Don't kill background jobs on exit
setopt LOCAL_OPTIONS             # Allow functions to have local options
setopt LOCAL_TRAPS               # Allow functions to have local traps
setopt PROMPT_SUBST              # Enable prompt substitution
setopt IGNORE_EOF                # Don't exit on Ctrl-D

# ------------------------------------------------------------
# OS Detection & Paths
# ------------------------------------------------------------

source "$HOME/.zsh/os-detect.zsh"
source "$HOME/.zsh/paths.zsh"

{{- if eq .profile "full" }}
# ------------------------------------------------------------
# Antidote Plugin Manager (must load before compinit for zsh-completions)
# ------------------------------------------------------------

# Determine Antidote path
if [[ -f "${HOMEBREW_PREFIX:-/opt/homebrew}/opt/antidote/share/antidote/antidote.zsh" ]]; then
    ANTIDOTE_HOME="${HOMEBREW_PREFIX:-/opt/homebrew}/opt/antidote/share/antidote"
elif [[ -f "/home/linuxbrew/.linuxbrew/opt/antidote/share/antidote/antidote.zsh" ]]; then
    ANTIDOTE_HOME="/home/linuxbrew/.linuxbrew/opt/antidote/share/antidote"
elif [[ -f "$HOME/.antidote/antidote.zsh" ]]; then
    ANTIDOTE_HOME="$HOME/.antidote"
fi

if [[ -n "$ANTIDOTE_HOME" ]]; then
    source "${ANTIDOTE_HOME}/antidote.zsh"

    # Generate static plugin file if needed (or if antidote was upgraded)
    zsh_plugins="$HOME/.zsh_plugins"
    if [[ ! "${zsh_plugins}.zsh" -nt "${zsh_plugins}.txt" ]] || \
       ! grep -q "$ANTIDOTE_HOME" "${zsh_plugins}.zsh" 2>/dev/null; then
        antidote bundle <"${zsh_plugins}.txt" >"${zsh_plugins}.zsh"
    fi
    source "${zsh_plugins}.zsh"
fi
{{- else }}
# ------------------------------------------------------------
# Powerlevel10k (minimal profile - direct load without antidote)
# ------------------------------------------------------------
[[ -f "${HOME}/.powerlevel10k/powerlevel10k.zsh-theme" ]] && \
    source "${HOME}/.powerlevel10k/powerlevel10k.zsh-theme"
{{- end }}

# ------------------------------------------------------------
# Completion System (after Antidote adds zsh-completions to fpath)
# ------------------------------------------------------------

# Initialize completion (with caching for speed)
autoload -Uz compinit
if [[ -n "$HOME/.zcompdump"(N.mh-24) ]]; then
    compinit -C  # Cache exists and fresh, skip security check
else
    compinit     # Cache missing or stale, regenerate with security check
fi

source "$HOME/.zsh/completion.zsh"

# ------------------------------------------------------------
# Tool Integrations
# ------------------------------------------------------------
{{- if .install_atuin }}

# Atuin (shell history)
if command -v atuin &>/dev/null; then
    eval "$(atuin init zsh --disable-up-arrow)"
fi
{{- end }}
{{- if .install_zoxide }}

# Zoxide (smart cd)
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh)"
fi
{{- end }}
{{- if .install_fzf }}

# FZF (fuzzy finder)
if [[ -f "$HOME/.fzf.zsh" ]]; then
    source "$HOME/.fzf.zsh"
elif command -v fzf &>/dev/null; then
    eval "$(fzf --zsh)"
fi

# direnv (per-directory environment variables)
if command -v direnv &>/dev/null; then
    eval "$(direnv hook zsh)"
fi
{{- end }}

# ------------------------------------------------------------
# Aliases
# ------------------------------------------------------------

for alias_file in "$HOME/.zsh/aliases"/*.zsh; do
    [[ -f "$alias_file" ]] && source "$alias_file"
done

# ------------------------------------------------------------
# Functions
# ------------------------------------------------------------

# Add functions to fpath for autoloading
fpath=("$HOME/.zsh/functions" $fpath)

# Autoload shellkit functions
autoload -Uz shellkit reload sshx tw git-delete-local-merged git-all git-amend git-credit git-undo git-promote git-up
{{- if eq .profile "full" }}
autoload -Uz mon sudo-biometrics secrets
{{- end }}

# ------------------------------------------------------------
# Key Bindings
# ------------------------------------------------------------

# Emacs-style line editing
bindkey -e

# Word navigation
bindkey '^[[1;5D' backward-word     # Ctrl+Left
bindkey '^[[1;5C' forward-word      # Ctrl+Right
bindkey '^[^[[D' backward-word      # Alt+Left (iTerm2)
bindkey '^[^[[C' forward-word       # Alt+Right (iTerm2)

# Line navigation
bindkey '^[[H' beginning-of-line    # Home
bindkey '^[[F' end-of-line          # End
bindkey '^[[5D' beginning-of-line   # Ctrl+Left (iTerm2)
bindkey '^[[5C' end-of-line         # Ctrl+Right (iTerm2)

# Deletion
bindkey '^[[3~' delete-char         # Delete
bindkey '^?' backward-delete-char   # Backspace

# History substring search (only bind if widget exists)
if (( ${+widgets[history-substring-search-up]} )); then
    bindkey '^[[A' history-substring-search-up
    bindkey '^[[B' history-substring-search-down
fi

{{- if eq .profile "full" }}
# AI command prompt (Alt-A: describe in English, get shell command)
if command -v claude &>/dev/null; then
    source "$HOME/.zsh/ai-prompt.zsh"
fi

# Pet snippet manager (Ctrl-S: search and insert snippets)
if command -v pet &>/dev/null; then
    source "$HOME/.zsh/pet-select.zsh"
fi
{{- end }}

# ------------------------------------------------------------
# Powerlevel10k Configuration (must be at end)
# ------------------------------------------------------------

[[ -f "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"

# ------------------------------------------------------------
# iTerm2 Shell Integration (macOS)
# ------------------------------------------------------------

[[ -f "${HOME}/.iterm2_shell_integration.zsh" ]] && source "${HOME}/.iterm2_shell_integration.zsh"

# ------------------------------------------------------------
# Startup Time Recording (fires once on first prompt)
# ------------------------------------------------------------

_shellkit_record_startup() {
    add-zsh-hook -d precmd _shellkit_record_startup

    if [[ -n "$SHELLKIT_ZSH_START" ]]; then
        local duration_ms
        (( duration_ms = (EPOCHREALTIME - SHELLKIT_ZSH_START) * 1000 ))
        local metrics_dir="${HOME}/.local/share/shellkit"
        [[ -d "$metrics_dir" ]] || mkdir -p "$metrics_dir"
        local metrics_file="${metrics_dir}/metrics.jsonl"
        local ts=$(strftime '%Y-%m-%dT%H:%M:%S%z' $EPOCHSECONDS)
        local hostname="${HOST:-$(hostname -s)}"
        printf '{"ts":"%s","duration_ms":%.1f,"host":"%s"}\n' \
            "$ts" "$duration_ms" "$hostname" \
            >> "$metrics_file"

        # Rotate if too large (keep last 200 entries)
        if [[ -f "$metrics_file" ]] && (( $(wc -l < "$metrics_file") > 500 )); then
            tail -200 "$metrics_file" > "${metrics_file}.tmp" && mv "${metrics_file}.tmp" "$metrics_file"
        fi
    fi
    unset SHELLKIT_ZSH_START
}
add-zsh-hook precmd _shellkit_record_startup

# ------------------------------------------------------------
# Local Customizations (not managed by chezmoi)
# ------------------------------------------------------------
# Create ~/.zshrc.local for machine-specific config that won't
# conflict with shellkit updates. This file is sourced last,
# so it can override any settings above.

[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
