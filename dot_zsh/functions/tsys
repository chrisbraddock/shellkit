#!/usr/bin/env zsh
# tsys - 4-pane tmux workspace with claude in each pane
# Usage: tsys [path]   (defaults to current directory)

local repo_path="${1:-.}"
repo_path="${repo_path:A}"

local repo_name="${repo_path:t}"
repo_name="${repo_name//[^[:alnum:]]/_}"
local session="sys_${repo_name}"

if tmux has-session -t "$session" 2>/dev/null; then
    exec tmux attach -t "$session"
fi

# Create session — pane 0 (top-left)
tmux new-session -d -s "$session" -c "$repo_path"

# Split right — pane 1 (top-right)
tmux split-window -h -t "$session" -c "$repo_path"

# Split top-left down — pane 2 (bottom-left)
tmux select-pane -t "${session}.0"
tmux split-window -v -t "$session" -c "$repo_path"

# Split top-right down — pane 3 (bottom-right)
tmux select-pane -t "${session}.1"
tmux split-window -v -t "$session" -c "$repo_path"

# Run claude in all 4 panes
tmux send-keys -t "${session}.0" 'claude' C-m
tmux send-keys -t "${session}.1" 'claude' C-m
tmux send-keys -t "${session}.2" 'claude' C-m
tmux send-keys -t "${session}.3" 'claude' C-m

# Focus top-left
tmux select-pane -t "${session}.0"

exec tmux attach -t "$session"
