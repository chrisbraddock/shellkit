#!/usr/bin/env zsh
# tdev - AI dev workspace: claude + codex + shell
# Usage: tdev [path]   (defaults to current directory)

local repo_path="${1:-.}"
repo_path="${repo_path:A}"

local repo_name="${repo_path:t}"
repo_name="${repo_name//[^[:alnum:]]/_}"
local session="ai_${repo_name}"

if tmux has-session -t "$session" 2>/dev/null; then
    exec tmux attach -t "$session"
fi

# Create session — pane 0 (left: claude)
tmux new-session -d -s "$session" -c "$repo_path"

# Split right — pane 1 (right: codex)
tmux split-window -h -t "${session}:0.0" -c "$repo_path"

# Split pane 1 vertically — pane 2 (bottom-right: shell)
tmux split-window -v -t "${session}:0.1" -c "$repo_path"

# Send commands to each pane
tmux send-keys -t "${session}:0.0" 'claude --continue' C-m
tmux send-keys -t "${session}:0.1" 'codex continue' C-m
tmux send-keys -t "${session}:0.2" 'clear' C-m

# Focus left pane (claude)
tmux select-pane -t "${session}:0.0"

exec tmux attach -t "$session"
