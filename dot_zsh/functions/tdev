#!/usr/bin/env zsh
# tdev - AI dev workspace: claude + codex + shell
# Usage: tdev [path]   (defaults to current directory)

local repo_path="${1:-.}"
repo_path="${repo_path:A}"

local repo_name="${repo_path:t}"
repo_name="${repo_name//[^[:alnum:]]/_}"
local session="ai_${repo_name}"

if tmux has-session -t "$session" 2>/dev/null; then
    exec tmux attach -t "$session"
fi

# Create session — left pane (claude)
tmux new-session -d -s "$session" -c "$repo_path" -PF '#{pane_id}'
local left_pane=$(tmux display-message -t "$session" -p '#{pane_id}')

# Split right (codex)
local right_pane=$(tmux split-window -h -t "$left_pane" -c "$repo_path" -PF '#{pane_id}')

# Split the right pane top/bottom (shell)
local bottom_pane=$(tmux split-window -v -t "$right_pane" -c "$repo_path" -PF '#{pane_id}')

# Send commands to each pane by ID
tmux send-keys -t "$left_pane" 'claude --continue' C-m
tmux send-keys -t "$right_pane" 'codex resume' C-m
tmux send-keys -t "$bottom_pane" 'clear' C-m

# Focus left pane (claude)
tmux select-pane -t "$left_pane"

exec tmux attach -t "$session"
