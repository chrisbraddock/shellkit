#!/usr/bin/env zsh
# tdev - AI dev workspace: claude + codex + shell
# Usage: tdev [path]   (defaults to current directory)

local repo_path="${1:-.}"
repo_path="${repo_path:A}"

local repo_name="${repo_path:t}"
repo_name="${repo_name//[^[:alnum:]]/_}"
local session="ai_${repo_name}"

if tmux has-session -t "$session" 2>/dev/null; then
    exec tmux attach -t "$session"
fi

# Create session — left pane (claude)
tmux new-session -d -s "$session" -c "$repo_path"

# Split right (codex) — -h splits the current pane left|right
tmux split-window -h -t "$session" -c "$repo_path"

# Split the right pane top/bottom (shell) — -v splits current pane top|bottom
# After split-window, the new pane is active, so we target $session directly
tmux split-window -v -t "$session" -c "$repo_path"

# Send commands — use absolute pane indices via list-panes
tmux send-keys -t "${session}.0" 'claude --continue' C-m
tmux send-keys -t "${session}.1" 'codex resume' C-m
tmux send-keys -t "${session}.2" 'clear' C-m

# Focus left pane (claude)
tmux select-pane -t "${session}.0"

exec tmux attach -t "$session"
